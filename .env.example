# =============================================================================
# FRONTEND (Vite) — required for the app, AI assistant, and email invoke buttons
# =============================================================================
# Copy to .env.local (gitignored):  npm run setup:env
#
# Dashboard: Supabase → Project Settings → API
#   Project URL     → VITE_SUPABASE_URL
#   anon public key → VITE_SUPABASE_PUBLISHABLE_KEY  (never use service_role here)

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_jwt_here

# Optional (other features)
# VITE_SUPABASE_PROJECT_ID=YOUR_PROJECT_REF

# =============================================================================
# EDGE FUNCTIONS — set in Supabase Dashboard → Edge Functions → Secrets
# (or: supabase secrets set --env-file supabase/.env.secrets)
# Never commit real secrets; never put service_role in Vite env.
# =============================================================================
#
# --- Shared (most functions) ---
# SUPABASE_URL              = same project URL as above
# SUPABASE_SERVICE_ROLE_KEY = service_role JWT (Dashboard → API)
#
# --- send-notification-email (SMTP) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=Your App <noreply@yourdomain.com>
#
# --- ai-question-assistant ---
# GROQ_API_KEY=           (for Groq / "both" modes)
# GEMINI_API_KEY=         (for Gemini / "both" modes)
#
# Optional: if you have additional configuration
# SOME_CONFIG=value
